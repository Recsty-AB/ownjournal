# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Google Drive OAuth (optional - enables Google Drive sync)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Dropbox OAuth (optional - enables Dropbox sync)
VITE_DROPBOX_CLIENT_ID=your-dropbox-app-key

# Apple Sign-In (optional - currently disabled via feature flag)
VITE_APPLE_CLIENT_ID=your-apple-client-id

# Stripe (optional - enables subscriptions)
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
