{
	"appId": "app.ownjournal",
	"appName": "OwnJournal",
	"webDir": "dist",
	"plugins": {
		"App": {
			"appUrlOpen": {
				"enabled": true
			}
		}
	},
	"android": {
		"scheme": "ownjournal",
		"allowMixedContent": true
	},
	"ios": {
		"scheme": "ownjournal",
		"contentInset": "never",
		"backgroundColor": "#f9f8f5"
	},
	"packageClassList": [
		"OwnJournalQrScannerPlugin",
		"CloudKitPlugin",
		"AppleSignInPlugin",
		"FileOpenerPlugin",
		"AppPlugin",
		"CAPBrowserPlugin",
		"FilesystemPlugin",
		"SharePlugin"
	]
}
